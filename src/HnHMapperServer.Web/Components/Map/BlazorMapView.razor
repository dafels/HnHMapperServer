@using HnHMapperServer.Web.Models
@using HnHMapperServer.Core.DTOs
@inject IJSRuntime JS
@inject ILogger<BlazorMapView> Logger
@inject HnHMapperServer.Web.Services.Map.MapNavigationService Navigation
@inject HnHMapperServer.Web.Services.Map.LayerVisibilityService LayerVisibility
@inject HnHMapperServer.Web.Services.Map.CustomMarkerStateService CustomMarkerState
@inject HnHMapperServer.Services.Interfaces.IBuildInfoProvider BuildInfo
@implements IAsyncDisposable
@implements IMapView

<div class="blazor-map-viewport"
     @ref="viewportEl"
     style="position:relative; overflow:hidden; width:100%; height:100%; touch-action:none; cursor:grab; user-select:none; background:#1a1a1a;"
     @oncontextmenu="HandleContextMenu"
     @oncontextmenu:preventDefault="true"
     @oncontextmenu:stopPropagation="true">

    @if (viewport.Width > 0 && currentMapId > 0 && initialPanSet)
    {
        @* The pan layer's transform is owned by the shim via --pan-x / --pan-y.
           C# never sets these via inline style — that would clobber the shim's
           setting. Tiles and entities inside this layer use STABLE pan-layer
           coordinates (left = tx*100, etc.), so a pan that doesn't cross a
           tile boundary causes ZERO DOM diff: the shim shifts the whole layer
           via CSS, the foreach output is identical, Blazor sees no change. *@
        <div class="blazor-map-pan-layer"
             style="position:absolute; left:0; top:0; transform: translate3d(var(--pan-x,0px), var(--pan-y,0px), 0); will-change: transform;">

            @* Old-zoom layer — rendered during a zoom transition. Captures the
               tiles that were visible at the old zoom level, scaled to cover the
               same world area at the new zoom, fading out via inline CSS animation.
               Eliminates the black flash between zooms while new tiles load. *@
            @if (oldZoomLayer != null)
            {
                var zoomRatio = (double)oldZoomScale / viewport.Scale;
                var zoomRatioStr = zoomRatio.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
                <div @key="@($"oldlayer{oldZoomLayerVersion}")"
                     style="@($"position:absolute; left:0; top:0; transform: scale({zoomRatioStr}); transform-origin: 0 0; pointer-events:none; animation: bmv-zoom-fade 1200ms ease-out forwards;")">
                    @foreach (var t in oldZoomLayer)
                    {
                        var oldTileLeft = t.Key.X * 100;
                        var oldTileTop = t.Key.Y * 100;
                        <img @key="@($"oldt{t.Key.MapId}_{t.Key.Zoom}_{t.Key.X}_{t.Key.Y}")"
                             src="@t.Url"
                             draggable="false"
                             onerror="this.style.visibility='hidden'"
                             style="@($"position:absolute; left:{oldTileLeft}px; top:{oldTileTop}px; width:100px; height:100px; image-rendering:pixelated; pointer-events:none;")" />
                    }
                </div>
            }

            @* Base tile layer — positions constant per (tx, ty).
               marginTiles=3 prefetches a ring of off-screen tiles so the browser
               has them cached before the user pans in. The viewport's overflow:hidden
               clips them — invisible until panned over. *@
            @foreach (var t in tileGrid.GetVisibleTiles(viewport, currentMapId, marginTiles: TileRenderMargin))
            {
                var tileLeft = t.Key.X * 100;
                var tileTop = t.Key.Y * 100;
                @* Each tile starts at opacity 0 and the inline onload handler bumps
                   it to 1, which CSS transitions over 250 ms. So tiles fade in
                   individually as they finish loading instead of popping. *@
                <img @key="t.Key"
                     src="@t.Url"
                     draggable="false"
                     loading="lazy"
                     onload="this.style.opacity=1"
                     onerror="this.style.visibility='hidden'"
                     style="@($"position:absolute; left:{tileLeft}px; top:{tileTop}px; width:100px; height:100px; image-rendering:pixelated; pointer-events:none; opacity:0; transition: opacity 250ms ease-out;")" />
            }

            @* Grid coordinate overlay. *@
            @if (State.ShowGridCoordinates)
            {
                @foreach (var t in tileGrid.GetVisibleTiles(viewport, currentMapId, marginTiles: 0))
                {
                    var tileLeft = t.Key.X * 100 + 2;
                    var tileTop = t.Key.Y * 100 + 2;
                    <div @key="@($"gc{t.Key.X}_{t.Key.Y}")"
                         style="@($"position:absolute; left:{tileLeft}px; top:{tileTop}px; color:#fff; text-shadow:1px 1px 2px #000; font-size:11px; font-family:monospace; pointer-events:none;")">
                        (@t.Key.X;@t.Key.Y)
                    </div>
                }
            }

            @* Roads — SVG positioned in pan-layer coords (negative coords supported via overflow:visible). *@
            @if (ShowRoads && Roads != null)
            {
                <svg style="position:absolute; left:0; top:0; width:1px; height:1px; overflow:visible; pointer-events:none;">
                    @foreach (var road in Roads)
                    {
                        if (road.MapId != currentMapId || road.Hidden) continue;
                        if (road.Waypoints == null || road.Waypoints.Count < 2) continue;
                        var pts = string.Join(' ', road.Waypoints.Select(w =>
                        {
                            var (px, py) = MapMath.WorldPxToPanLayer(viewport, w.CoordX * 100 + w.X, w.CoordY * 100 + w.Y);
                            return $"{px},{py}";
                        }));
                        var roadIdLocal = road.Id;
                        <polyline @key="@($"rd{road.Id}")"
                                  points="@pts"
                                  stroke="@RoadColor(road.Id)"
                                  stroke-width="3"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  fill="none"
                                  style="pointer-events:stroke; cursor:pointer;"
                                  @oncontextmenu="@((MouseEventArgs e) => HandleRoadContextMenu(roadIdLocal, e))"
                                  @oncontextmenu:preventDefault="true"
                                  @oncontextmenu:stopPropagation="true" />
                    }
                </svg>
            }

            @* Game markers (with v3 clustering at lower zoom). *@
            @if (State.ShowMarkers)
            {
                var clustersOrMarkers = ComputeMarkerDisplay();
                @foreach (var item in clustersOrMarkers)
                {
                    if (item.IsCluster)
                    {
                        var count = item.Count;
                        <div @key="@($"cl{item.SortKey}")"
                             style="@($"position:absolute; left:{item.Sx - 18}px; top:{item.Sy - 18}px; width:36px; height:36px; border-radius:50%; background:rgba(76,175,80,0.85); border:2px solid #fff; color:#fff; display:flex; align-items:center; justify-content:center; font-weight:bold; font-size:12px; pointer-events:none;")">
                            @count
                        </div>
                    }
                    else
                    {
                        var m = item.Marker!;
                        var markerIdLocal = m.Id;
                        var isThingwall = m.Type == "thingwall";
                        var isQuestGiver = m.Type == "questgiver";
                        var glowColor =
                            isThingwall && ShowThingwallHighlight ? "#00e5ff" :
                            isQuestGiver && ShowQuestGiverHighlight ? "#5cd85a" :
                            null;
                        var showLabel =
                            (isThingwall && State.ShowThingwallTooltips) ||
                            (isQuestGiver && State.ShowQuestTooltips);
                        var imgStyle = glowColor == null
                            ? $"position:absolute; left:{item.Sx - 12}px; top:{item.Sy - 12}px; width:24px; height:24px; cursor:pointer;"
                            : $"position:absolute; left:{item.Sx - 12}px; top:{item.Sy - 12}px; width:24px; height:24px; cursor:pointer; filter: drop-shadow(0 0 4px {glowColor}) drop-shadow(0 0 8px {glowColor});";
                        <img @key="@($"mk{m.Id}")"
                             src="@($"/{m.Image}.png")"
                             draggable="false"
                             title="@m.Name"
                             @onclick="@(() => HandleMarkerClick(markerIdLocal))"
                             @oncontextmenu="@((MouseEventArgs e) => HandleMarkerContextMenu(markerIdLocal, e))"
                             @oncontextmenu:preventDefault="true"
                             @oncontextmenu:stopPropagation="true"
                             style="@imgStyle" />
                        @if (showLabel)
                        {
                            <div @key="@($"mklbl{m.Id}")"
                                 style="@($"position:absolute; left:{item.Sx}px; top:{item.Sy + 16}px; transform:translateX(-50%); white-space:nowrap; background:rgba(0,0,0,0.7); color:#fff; padding:1px 4px; font-size:10px; border-radius:2px; pointer-events:none;{(glowColor != null ? $" box-shadow:0 0 4px {glowColor};" : "")}")">
                                @m.Name
                            </div>
                        }
                    }
                }
            }

            @* Custom markers. *@
            @if (State.ShowCustomMarkers)
            {
                @foreach (var cm in CustomMarkerState.AllCustomMarkers)
                {
                    if (cm.MapId != currentMapId || cm.Hidden) continue;
                    var worldPxX = cm.CoordX * 100 + cm.X;
                    var worldPxY = cm.CoordY * 100 + cm.Y;
                    var (px, py) = MapMath.WorldPxToPanLayer(viewport, worldPxX, worldPxY);
                    if (!IsInVisibleWorldRange(px, py, 32)) continue;
                    var cmIdLocal = cm.Id;
                    <img @key="@($"cm{cm.Id}")"
                         src="@(ResolveCustomMarkerIcon(cm.Icon))"
                         draggable="false"
                         title="@cm.Title"
                         @oncontextmenu="@((MouseEventArgs e) => HandleCustomMarkerContextMenu(cmIdLocal, e))"
                         @oncontextmenu:preventDefault="true"
                         @oncontextmenu:stopPropagation="true"
                         style="@($"position:absolute; left:{px - 12}px; top:{py - 12}px; width:24px; height:24px; cursor:pointer;")" />
                }
            }

            @* Characters. *@
            @if (State.ShowPlayers)
            {
                @foreach (var c in characters.Values)
                {
                    if (c.Map != currentMapId) continue;
                    var (px, py) = MapMath.WorldPxToPanLayer(viewport, c.Position.X, c.Position.Y);
                    if (!IsInVisibleWorldRange(px, py, 32)) continue;
                    <div @key="@($"ch{c.Id}")"
                         class="blazor-map-character"
                         style="@($"position:absolute; left:{px - 8}px; top:{py - 8}px; width:16px; height:16px; border-radius:50%; background:{(c.Type == "self" ? "#ffd54f" : "#42a5f5")}; border:2px solid #fff; transform: rotate({c.Rotation}deg); pointer-events:none;")">
                        @if (State.ShowPlayerTooltips)
                        {
                            <span style="position:absolute; top:18px; left:50%; transform:translateX(-50%); white-space:nowrap; background:rgba(0,0,0,0.7); color:#fff; padding:1px 4px; font-size:10px; border-radius:2px;">@c.Name</span>
                        }
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#888;">
            <span>Initializing map...</span>
        </div>
    }
</div>
